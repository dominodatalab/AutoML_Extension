# Domino Environment Variables for AutoML UI
# Copy this file to .env.local for local development

# Base path for the application (set automatically in Domino via setup script)
# For Domino workspaces, this is typically: /notebookSession/{session_id}/proxy/3000/
VITE_BASE_PATH=/

# API URL for the FastAPI backend
# Local development: http://localhost:8000
# Domino workspace: typically same-origin, so leave as default
VITE_API_URL=http://localhost:8000

# Model API URL (if using external model endpoint)
# VITE_MODEL_API_URL=https://your-model-api.domino.tech

# Model API Token (if required)
# VITE_MODEL_API_TOKEN=your-token-here
